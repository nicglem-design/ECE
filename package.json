{
  "name": "kanox",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "cd apps/api && npm run test",
    "test:coverage": "cd apps/api && npm run test:coverage",
    "test:e2e": "npm-run-all test:e2e-auth test:e2e-support test:e2e-fiat",
    "test:e2e-auth": "npx tsx scripts/e2e-auth-flow.ts",
    "test:e2e-support": "npx tsx scripts/e2e-support-flow.ts",
    "test:e2e-fiat": "npx tsx scripts/e2e-fiat-flow.ts",
    "dev": "ulimit -n 65536 2>/dev/null || true; npm-run-all --parallel dev:web dev:api",
    "dev:web": "ulimit -n 65536 2>/dev/null || true; cd apps/web && npx next dev --hostname 127.0.0.1 --webpack",
    "dev:api": "cd apps/api && npm run build && node dist/main.js",
    "dev:web-only": "ulimit -n 65536 2>/dev/null || true; cd apps/web && npx next dev --hostname 127.0.0.1 --webpack",
    "dev:web-alt": "cd apps/web && npx next dev --hostname 127.0.0.1 -p 3002 --webpack",
    "start": "npm-run-all --parallel start:web start:api",
    "start:web": "cd apps/web && npm run start",
    "start:api": "cd apps/api && node dist/main.js"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
