# =============================================================================
# ECE API – Environment variables
# Copy to .env and configure for your deployment.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED in production
# -----------------------------------------------------------------------------
# App exits if unset when NODE_ENV=production
JWT_SECRET=your-secret-key-min-32-chars

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=4000
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (default). Path to database file.
# DATABASE_PATH=./data/kanox.db

# PostgreSQL / Supabase. When set, uses Postgres instead of SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Real custody (wallets)
# -----------------------------------------------------------------------------
# When set, generates real wallets, signs and broadcasts on-chain.
# WALLET_ENCRYPTION_KEY overrides JWT_SECRET for key encryption (recommended: separate key).
# WALLET_ENCRYPTION_KEY=min-16-chars

# EVM chains (Ethereum, BNB, Polygon, Avalanche)
# ETH_RPC_URL=https://eth.llamarpc.com
# ETHEREUM_RPC_URL=https://eth.llamarpc.com
# BNB_RPC_URL=https://bsc-dataseed.binance.org
# POLYGON_RPC_URL=https://polygon-rpc.com
# AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Bitcoin
# BITCOIN_API_URL=https://mempool.space/api

# Litecoin
# LITECOIN_API_URL=https://blockstream.info/litecoin/api

# Dogecoin
# DOGECOIN_API_URL=https://api.blockcypher.com/v1/doge/main

# Solana
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# -----------------------------------------------------------------------------
# Block explorers (for deposit sync & tx status)
# -----------------------------------------------------------------------------
# Etherscan-style APIs. Without keys, public APIs are rate-limited.
# ETHERSCAN_API_KEY=
# ETHEREUM_ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# KYC (Sumsub)
# -----------------------------------------------------------------------------
# Optional. KYC works in stub mode without these.
# Webhook: POST https://your-api/api/v1/kyc/webhook for applicantReviewed
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_BASE_URL=https://api.sumsub.com

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://yoursite.com/accounts?deposit=success
# STRIPE_CANCEL_URL=https://yoursite.com/accounts?deposit=cancelled
# STRIPE_CONNECT_RETURN_URL=https://yoursite.com/accounts?connect=success
# STRIPE_CONNECT_REFRESH_URL=https://yoursite.com/accounts?connect=refresh

# -----------------------------------------------------------------------------
# OpenAI (AI chat)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-key-here

# -----------------------------------------------------------------------------
# Market / order book
# -----------------------------------------------------------------------------
# Optional. For server-to-server market maker orders.
# API_INTERNAL_KEY=your-internal-key
