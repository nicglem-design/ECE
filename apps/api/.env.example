# REQUIRED in production – app exits if unset when NODE_ENV=production
JWT_SECRET=your-secret-key-min-32-chars

# OpenAI API key – for Kano AI (optional)
# OPENAI_API_KEY=sk-your-key-here

# Database path (optional, default: ./data/kanox.db)
# DATABASE_PATH=./data/kanox.db

# Sumsub KYC (optional – KYC works in stub mode without these)
# Configure webhook: POST https://your-api/api/v1/kyc/webhook for applicantReviewed
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_BASE_URL=https://api.sumsub.com

# Real custody (EVM chains). When set, generates real wallets, real send, chain balance.
# WALLET_ENCRYPTION_KEY=min-16-chars  # or JWT_SECRET is used
# ETH_RPC_URL=https://eth.llamarpc.com
# ETHERSCAN_API_KEY=  # for deposit detection (optional, rate limited without)

# Stripe payments
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://yoursite.com/accounts?deposit=success
# STRIPE_CANCEL_URL=https://yoursite.com/accounts?deposit=cancelled
