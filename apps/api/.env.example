# =============================================================================
# ECE API – Environment variables
# Copy to .env and configure for your deployment.
# =============================================================================
#
# Quick start (local dev):
#   1. Copy this file to .env
#   2. Set JWT_SECRET (min 32 chars) – required
#   3. Set RESEND_API_KEY for email (verification, password reset)
#   4. Set APP_URL and FRONTEND_URL to http://localhost:3000
#   5. Optional: WALLET_ENCRYPTION_KEY for real custody (or use JWT_SECRET)
#   6. Optional: RPC URLs for real on-chain sends (defaults work for testing)
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED in production
# -----------------------------------------------------------------------------
# App exits if unset when NODE_ENV=production. Min 32 chars.
JWT_SECRET=your-secret-key-min-32-chars

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=4000
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (default). Path to database file.
# DATABASE_PATH=./data/kanox.db

# PostgreSQL / Supabase. When set, uses Postgres instead of SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Real custody (wallets)
# -----------------------------------------------------------------------------
# When set, generates real wallets, signs and broadcasts on-chain.
# WALLET_ENCRYPTION_KEY overrides JWT_SECRET for key encryption (recommended: separate key).
# WALLET_ENCRYPTION_KEY=min-16-chars

# EVM chains. For production, use Alchemy/Infura/QuickNode (see docs/PRODUCTION.md).
# ETH_RPC_URL=https://eth.llamarpc.com
# ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# BNB_RPC_URL=https://bsc-dataseed.binance.org
# POLYGON_RPC_URL=https://polygon-rpc.com
# AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Bitcoin (mempool.space is free; works for production)
# BITCOIN_API_URL=https://mempool.space/api

# Litecoin
# LITECOIN_API_URL=https://blockstream.info/litecoin/api

# Dogecoin (BlockCypher free tier is rate-limited)
# DOGECOIN_API_URL=https://api.blockcypher.com/v1/doge/main

# Solana (for production use Helius/QuickNode)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# -----------------------------------------------------------------------------
# Block explorers (for deposit sync & tx status)
# -----------------------------------------------------------------------------
# Etherscan-style APIs. Without keys, public APIs are rate-limited.
# ETHERSCAN_API_KEY=
# ETHEREUM_ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# KYC (Sumsub)
# -----------------------------------------------------------------------------
# Optional. When configured, fiat deposits and withdrawals require KYC approval.
# Without these, KYC is in stub mode (no enforcement).
# Webhook: POST https://your-api/api/v1/kyc/webhook for applicantReviewed
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_BASE_URL=https://api.sumsub.com

# -----------------------------------------------------------------------------
# Stripe (deposits – card + Apple Pay; Connect – bank withdrawals)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://yoursite.com/accounts?deposit=success
# STRIPE_CANCEL_URL=https://yoursite.com/accounts?deposit=cancelled
# Webhook: POST https://your-api/api/v1/accounts/stripe-webhook for checkout.session.completed
#
# Stripe Connect (bank withdrawals). Users redirect here after onboarding.
# STRIPE_CONNECT_RETURN_URL=https://yoursite.com/accounts?connect=success
# STRIPE_CONNECT_REFRESH_URL=https://yoursite.com/accounts?connect=refresh

# -----------------------------------------------------------------------------
# Email (Resend) – for verification & password reset
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_...
# EMAIL_FROM=ECE <noreply@yourdomain.com>
# APP_URL=https://yoursite.com
# FRONTEND_URL=https://yoursite.com
# APP_NAME=ECE

# -----------------------------------------------------------------------------
# OpenAI (AI chat)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-key-here

# -----------------------------------------------------------------------------
# Market maker (order book liquidity)
# -----------------------------------------------------------------------------
# Seed order book on API startup for instant swaps. Or call POST /api/v1/cron/seed-market-maker
# (with CRON_SECRET or API_INTERNAL_KEY) periodically.
# SEED_MARKET_MAKER_ON_START=true

# -----------------------------------------------------------------------------
# Limits (compliance)
# -----------------------------------------------------------------------------
# Max fiat withdrawal (USD equivalent) per user per 24h. 0 = no limit.
# WITHDRAWAL_LIMIT_DAILY=10000
# Max crypto send count per user per 24h. 0 = no limit.
# SEND_LIMIT_DAILY=20

# -----------------------------------------------------------------------------
# Cron (deposit sync)
# -----------------------------------------------------------------------------
# Protects POST /api/v1/cron/sync-deposits. Web cron sends Bearer CRON_SECRET.
# API_INTERNAL_KEY also accepted. Set one for production.
# CRON_SECRET=your-cron-secret

# -----------------------------------------------------------------------------
# Market / order book
# -----------------------------------------------------------------------------
# Optional. For server-to-server market maker orders.
# API_INTERNAL_KEY=your-internal-key
