# OpenAI API key – required for Kano AI to give full AI answers.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# JWT secret – change in production
JWT_SECRET=your-secret-key-change-in-production

# Database path (optional, default: ./data/kanox.db)
# DATABASE_PATH=./data/kanox.db

# Sumsub KYC (optional – KYC works in stub mode without these)
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_BASE_URL=https://api.sumsub.com
