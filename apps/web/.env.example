# API backend URL - used by Next.js rewrites to proxy /api/v1/* requests.
# Default: http://localhost:4000 (when running npm run dev with both web + api)
# API_BACKEND_URL=http://localhost:4000

# Optional: Override API base for client-side fetches (e.g. when API is on different domain)
# NEXT_PUBLIC_API_URL=http://localhost:4000
