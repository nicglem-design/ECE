# =============================================================================
# ECE Web – Environment variables
# Copy to .env.local and configure for your deployment.
# =============================================================================
#
# Quick start (local dev):
#   1. Copy this file to .env.local
#   2. API_BACKEND_URL=http://localhost:4000 (default – API must be running)
#   3. No other vars required for basic wallet + exchange
#
# =============================================================================

# -----------------------------------------------------------------------------
# API backend
# -----------------------------------------------------------------------------
# Used by Next.js rewrites to proxy /api/v1/* to the API server.
# Default: http://localhost:4000 (when running web + api together)
# API_BACKEND_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Client-side API URL
# -----------------------------------------------------------------------------
# Override when API is on a different domain (e.g. api.yoursite.com).
# NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Swap execution
# -----------------------------------------------------------------------------
# When "true" or "1", swaps execute via the order book (real execution).
# When unset or "false", swaps are simulated for demo.
# SWAP_REAL_MONEY=true

# -----------------------------------------------------------------------------
# Market maker / internal API
# -----------------------------------------------------------------------------
# Optional. For server-to-server market maker orders via X-Internal-Key.
# API_INTERNAL_KEY=your-internal-key

# -----------------------------------------------------------------------------
# Cron (Vercel)
# -----------------------------------------------------------------------------
# For deposit sync (every 15 min) and daily crypto sync. Set in Vercel dashboard.
# CRON_SECRET=your-cron-secret
# API_BACKEND_URL=https://your-api-domain.com  # required for cron to reach API
# NEXT_PUBLIC_APP_URL=https://yoursite.com
# VERCEL_URL is set automatically by Vercel
